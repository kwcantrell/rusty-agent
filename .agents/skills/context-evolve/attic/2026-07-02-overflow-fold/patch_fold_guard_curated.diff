+    #[tokio::test]
+    async fn compaction_folds_overflow_user_turns_recall_only() {
+        // When verbatim user turns alone outgrow the window's user budget, the
+        // OLDEST leave history for the offload store (recall-only; NOT
+        // paraphrased into a summary) — here the old span is all user turns,
+        // so the fold commits without any summarizer call.
+        let mut c = ctx();
+        c.high_water_pct = 0.0; // force compaction
+        c.config.keep_recent = 1;
+        for i in 0..12 {
+            c.append(Message::user(format!(
+                "ledger entry number {i}: setting item_{i} is assigned value {i}{i}{i}{i} for the manifest"
+            )));
+        }
+        c.append(Message::assistant("working on it", None));
+        let model: Arc<dyn ModelClient> = Arc::new(ScriptedModel::new(vec![]));
+        let sink: Arc<dyn EventSink> = Arc::new(CollectingSink::default());
+        let cancel = CancellationToken::new();
+        let mut deps = maint_deps(&model, &sink, &cancel);
+        // Small window: user turns (~280 est tok total) exceed the budget.
+        deps.model_limit = 250;
+        let report = c.maintain(&deps).await;
+
+        assert!(report.offloaded >= 1, "fold must commit to the store");
+        let kept_users: Vec<usize> = c
+            .history()
+            .iter()
+            .filter(|m| matches!(m.role, Role::User))
+            .filter_map(|m| {
+                m.content
+                    .split_whitespace()
+                    .nth(3)
+                    .and_then(|s| s.trim_end_matches(':').parse().ok())
+            })
+            .collect();
+        assert!(
+            !kept_users.is_empty() && kept_users.len() < 12,
+            "some but not all user turns stay verbatim: {kept_users:?}"
+        );
+        // The kept set is the NEWEST suffix — the oldest folded first.
+        let oldest_kept = *kept_users.iter().min().unwrap();
+        assert!(
+            kept_users.iter().all(|&i| i >= oldest_kept) && !kept_users.contains(&0),
+            "oldest user turns must be the folded ones: {kept_users:?}"
+        );
+        // The folded text is recoverable verbatim, and the marker is pinned
+        // even with no compaction summary present.
+        let entry = c.store.get(1).expect("folded entry stored");
+        assert!(entry.content.contains("item_0"));
+        let built = c.build(100_000);
+        assert!(
+            built
+                .iter()
+                .any(|m| m.content.contains("context_recall(1)")),
+            "marker pinned without a summary block"
+        );
+    }
