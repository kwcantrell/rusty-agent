+/// Prefix of the synthetic in-history user message a fold leaves behind. Kept
+/// in-history (not in a pinned block) for salience — models act on markers they
+/// read in conversation flow (see offload placeholders) and ignore ones buried
+/// in a pinned system block. Marker units are never themselves folded.
+const FOLD_MARKER_PREFIX: &str = "[context notice:";
+
+/// Offload ids referenced by a fold marker (`context_recall(<id>)` mentions).
+fn parse_marker_ids(content: &str) -> Vec<crate::OffloadId> {
+    content
+        .split("context_recall(")
+        .skip(1)
+        .filter_map(|rest| {
+            rest.split(')')
+                .next()
+                .and_then(|d| d.trim().parse::<crate::OffloadId>().ok())
+        })
+        .collect()
+}
