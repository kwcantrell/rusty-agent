# Local daemon enrollment config (holds an agent token) — never commit
agent-server.json

# Environment / secret files (catch-all; cloud/.dev.vars has its own rule too)
.env
.env.*

# Editor / OS junk
.DS_Store
.idea/
.vscode/

# Graphify local caches + generated outputs — rebuild with `/graphify .`
# (this also covers the .graphify_* temp files and manifest.json it writes inside)
graphify-out/
# NOTE: .graphifyignore is intentionally committed (it holds the corpus exclusion
# rules), so do NOT add a `.graphify*` glob here — it would hide that file.

# Superpowers SDD scratch (briefs, reports, diffs, ledger)
.superpowers/

# Local git worktrees (isolated workspaces for feature branches)
.worktrees/

# Playwright MCP scratch (snapshots, console logs from browser-driven debugging)
.playwright-mcp/

src-tauri/target/
src-tauri/gen/

node_modules/
